# Enforce consistent line endings across contributors on Windows / Unix.
# Rules of thumb:
#   - Source files : LF (Windows toolchains all accept LF; makes diffs cleaner)
#   - Windows-only scripts (.bat/.cmd/.ps1) and VS project files : CRLF
#   - Everything else                                             : text=auto

* text=auto eol=lf

# ---- C / C++ ---------------------------------------------------------------
*.c    text eol=lf
*.cc   text eol=lf
*.cpp  text eol=lf
*.cxx  text eol=lf
*.h    text eol=lf
*.hh   text eol=lf
*.hpp  text eol=lf
*.hxx  text eol=lf
*.inl  text eol=lf
*.ipp  text eol=lf

# ---- Build system ----------------------------------------------------------
CMakeLists.txt        text eol=lf
*.cmake               text eol=lf
CMakePresets.json     text eol=lf
*.ninja               text eol=lf

# ---- Config / metadata -----------------------------------------------------
*.json    text eol=lf
*.json5   text eol=lf
*.jsonc   text eol=lf
*.toml    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
.clang-format text eol=lf
.clang-tidy   text eol=lf
.editorconfig text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# ---- Windows-only scripts (must stay CRLF) --------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ---- Visual Studio project files (VS expects CRLF) ------------------------
*.sln           text eol=crlf
*.vcxproj       text eol=crlf
*.vcxproj.*     text eol=crlf
*.props         text eol=crlf
*.targets       text eol=crlf

# ---- Binary assets ---------------------------------------------------------
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.7z   binary
*.dll  binary
*.exe  binary
*.lib  binary
*.pdb  binary

# ---- linguist overrides (better GitHub language stats) ---------------------
docs/**              linguist-documentation
third_party/**       linguist-vendored
